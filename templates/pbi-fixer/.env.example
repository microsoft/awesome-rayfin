# =============================================================================
# Power BI Fixer — example environment file.
#
# Copy this file to `.env` and fill in the values for YOUR Fabric tenant and
# workspace. The rayfin CLI also generates `.env.local` automatically from
# `rayfin/.env` (run `rayfin env --framework vite`) — it holds the workspace /
# item / tenant ids and the Rayfin publishable key. Vite merges both files.
#
# None of these values are secret app credentials — they are public
# client/app-registration ids and the publicly invocable URLs of your own
# deployed User Data Functions. Never commit real secrets here.
# =============================================================================

# Entra SPA app-registration client id used for brokered Fabric auth.
VITE_FABRIC_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Public URLs of the three core Python User Data Functions you deploy from
# `fabric-udf/`. Replace <workspace-id> and <udf-item-id> with your own.
# The app derives the additional function URLs (fabric_proxy, github_* …)
# from these by substituting the function name, so only these three are required.
VITE_UDF_LIST_WORKSPACES_URL=https://<workspace-id-nodash>.z52.userdatafunctions.fabric.microsoft.com/v1/workspaces/<workspace-id>/userDataFunctions/<udf-item-id>/functions/list_workspaces/invoke
VITE_UDF_LIST_REPORTS_URL=https://<workspace-id-nodash>.z52.userdatafunctions.fabric.microsoft.com/v1/workspaces/<workspace-id>/userDataFunctions/<udf-item-id>/functions/list_reports/invoke
VITE_UDF_APPLY_FIXER_URL=https://<workspace-id-nodash>.z52.userdatafunctions.fabric.microsoft.com/v1/workspaces/<workspace-id>/userDataFunctions/<udf-item-id>/functions/apply_report_fixer/invoke

# Optional: override the generic proxy URL if it does not live on the same
# UDF item as list_workspaces (by default it is derived automatically).
# VITE_UDF_FABRIC_PROXY_URL=

# Optional: workspace that holds a ready-made monitoring sample report, used as
# the clone source for the one-click "deploy monitoring report" shortcut. Leave
# unset to disable the shortcut and use the manual .pbit import path instead.
# VITE_DEMO_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
