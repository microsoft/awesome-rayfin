{
  "name": "angular-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "template": {
    "name": "angular-dashboard",
    "displayName": "Angular Dashboard App",
    "description": "Responsive Angular Material dashboard — top navbar + collapsible side menu, Project/Task data model, and optional one-click GitHub Issues/PRs sync for a public repo."
  },
  "scripts": {
    "predev": "rayfin env --framework vite",
    "prebuild": "rayfin env --framework vite",
    "prebuild:fabric": "rayfin env --framework vite",
    "pretest": "rayfin env --framework vite",
    "dev": "rayfin up && ng serve --port 5173",
    "build": "ng build",
    "build:fabric": "ng build",
    "lint": "eslint .",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "rayfin:up": "rayfin up"
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@microsoft/rayfin-auth-provider-fabric": "^1.32.0",
    "@microsoft/rayfin-client": "^1.32.0",
    "@microsoft/rayfin-core": "^1.32.0",
    "@microsoft/rayfin-data": "^1.32.0",
    "chart.js": "^4.5.0",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^11.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@eslint/js": "^9.21.0",
    "@microsoft/rayfin-cli": "^1.23.0",
    "@ngx-env/builder": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.28.0",
    "globals": "^16.0.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.38.0"
  }
}
