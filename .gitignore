# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output/

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt/

# Bower dependency directory (https://bower.io/)
bower_components/

# node-waf configuration
.lock-wscript/

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release/

# Dependency directories
node_modules/
jspm_packages/

# Local git worktrees
.worktrees/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.development.local
.env.test.local
.env.production.local
.env.local
.env.production
.env.fabric
.env.fabric-*
.env.template

# Rayfin — auto-generated, may contain secrets
**/rayfin/.deployments.json
rayfin/.temp/

# next.js build output
.next/

# Docusaurus cache and generated files
.docusaurus/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# yarn v2
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# OS X temporary files
.DS_Store

# IntelliJ IDEA project files; if you want to commit IntelliJ settings, this recipe may be helpful:
# https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
.idea/
*.iml

# Visual Studio Code
.vscode/*
!.vscode/mcp.json
!.vscode/tasks.json
!.vscode/launch.json

# Rush temporary files
common/deploy/
common/temp/
common/autoinstallers/*/.npmrc
**/.rush/temp/
*.lock

# Common toolchain intermediate files
temp/
lib-amd/
lib-es6/
lib-esnext/
lib-commonjs/
lib-shim/
dist/
dist-storybook/
*.tsbuildinfo

# Heft temporary files
.cache/
.heft/

packages/**/*.d.ts
packages/**/*.d.ts.map
packages/**/*.js
!packages/docgen/**/*.js
!packages/tools/vscode/src/__mocks__/**/*.js
!packages/tools/vscode/src/webviews/typings.d.ts
!packages/tools/vscode/src/typings.d.ts
!packages/tools/common/src/typings.d.ts

packages/**/*.js.map

**/.temp

# But don't ignore important config files
!*.config.js
!vite.config.ts
!vitest.config.ts
!**/scripts/toggle-service-mode.js

# Generated Files
**/bin
**/obj
**/*.lscache
**/coverage
**/coveragereport
**/TestResults
**/test-results
test-results/
system-commandline-sentinel-files/
out/
publish/
log.txt

# only include appsettings for a few default environments
appsettings.*.json
dab-config*.json
*.dab-config.json
!dab-config.*reference.json
!dab-config.*.example.json
storage-config*.json

*.cd

.fake
.ionide
*.orig

# Nuget package
**/*.nupkg

# VS Code extension package
*.vsix
# Exception: Include DAB packages in local-packages for development
# TODO: In future we should get the packages from a dedicated pipeline in Github
!packages/host/local-packages/*.nupkg

# Local-Only files
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.fabric
.env.template

# Verify test files
*.received.*
.DS_Store

# Azurite
__azurite**
AzuriteConfig
__blobstorage__

# Playwright MCP
.playwright-mcp

# Rayfin asymmetric key storage (local development only)
keys/
*.pem

# Visual Studio folders
.vs
.idea

# User-specific files
*.suo
*.user
*.sln.docstates
*.csproj.user
*.DotSettings.user

# OpenSpec archived changes
# Work-in-progress proposals in openspec/changes/ should be tracked,
# but archived changes are already merged into mainline specs and
# become cruft that confuses bots and adds noise without value.
openspec/changes/archive/

# Generated assets
packages/tools/mcp/assets/docs
packages/tools/mcp/assets/docs.search.json

# Build artifact zips
*.zip

# VS Code extension debug files
.vscode-ext-debug*

.worktrees/
